{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "."
  },
  "include": [
    "pages/**/*.ts",
    "tests/**/*.ts",
    "fixtures/**/*.ts",
    "../playwright.config.ts"
  ],
  "exclude": ["archive/**"]
}
