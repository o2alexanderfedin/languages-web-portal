NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
VERSION=0.0.0

# ─── Java FV ──────────────────────────────────────────────────────────────────
# Path to the java-fv CLI jar (not available locally — see README)
# JAVA_FV_JAR=/path/to/java-fv/cli-1.1.0-jar-with-dependencies.jar
# JAVA_FV_CMD=/path/to/languages-web-portal/scripts/hupyy-java-verify.sh
JAVA_HOME=/Library/Java/JavaVirtualMachines/jdk-21.jdk/Contents/Home

# ─── C# FV ────────────────────────────────────────────────────────────────────
# Overrides toolRegistry default (/usr/local/bin/hupyy-csharp-verify used in Docker)
CSHARP_FV_CMD=/path/to/languages-web-portal/scripts/hupyy-csharp-verify.sh
# Path to the published cs-fv CLI DLL (dotnet publish output)
CS_FV_DLL=/path/to/cs-fv/src/CsFv.Cli/bin/Release/net8.0/publish/cs-fv.dll
# Path to cvc5 static binary (download from GitHub releases — see README)
CVC5_PATH=/path/to/bin/cvc5
